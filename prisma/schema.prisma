generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/client/" 
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int       @id @default(autoincrement())
  nome     String
  email    String
  senha    String
  produtor Produtor?
  avaliacao Avaliacao[]
}

model Produtor {
  id       Int       @id @default(autoincrement())
  bio      String
  contato  String
  endereco String
  estado   String
  cidade   String
  user_id  Int       @unique
  produtos Produto[]
  user     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Produto {
  id          Int         @id @default(autoincrement())
  titulo      String
  descricao   String
  preco       Decimal     @db.Decimal(10, 2)
  unit        String 
  categoria   String
  imageUrl    String?
  id_produtor Int
  createdAt   DateTime    @default(now())
  avaliacao   Avaliacao[]
  produtor    Produtor    @relation(fields: [id_produtor], references: [id], onDelete: Cascade)
}

model Avaliacao {
  id         Int     @id @default(autoincrement())
  comentario String
  nota       Int
  id_produto Int
  produto    Produto @relation(fields: [id_produto], references: [id], onDelete: Cascade)
  id_user Int
  user   User @relation(fields: [id_user],references: [id],onDelete: Cascade)
}
